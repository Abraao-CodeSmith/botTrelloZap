# =====================================================
# BotTrelloZap - Root .gitignore
# Covers Bot-TrelloWA and Evolution API
# =====================================================

# -----------------------------------------------------
# Dependencies
# -----------------------------------------------------
**/node_modules/

# -----------------------------------------------------
# Build / Compiled output
# -----------------------------------------------------
**/dist/
**/coverage/

# -----------------------------------------------------
# Environment files
# -----------------------------------------------------
**/.env
**/.env.*
!**/.env.example

# Specific Docker env
Docker/.env

# -----------------------------------------------------
# Logs
# -----------------------------------------------------
logs/
**/*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
jest_out*.txt
test_results.txt

# -----------------------------------------------------
# Runtime / Temporary files
# -----------------------------------------------------
temp/
**/temp/
store/
**/store/
docker-compose-data/
docker-data/

# -----------------------------------------------------
# Evolution API
# -----------------------------------------------------
instances/*
!instances/.gitkeep

src/env.yml
prisma/migrations/*

# -----------------------------------------------------
# Bot-TrelloWA
# -----------------------------------------------------
data/*.json
debug_evolution.js
docs/
grupozap/

# -----------------------------------------------------
# Tests
# -----------------------------------------------------
test/
__tests__/coverage/

# -----------------------------------------------------
# Package Managers
# -----------------------------------------------------
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------
# IDEs
# -----------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

.idea/
.nova/

# -----------------------------------------------------
# System files
# -----------------------------------------------------
.DS_Store
*.DS_Store
Thumbs.db

# -----------------------------------------------------
# Version managers
# -----------------------------------------------------
.tool-versions

# -----------------------------------------------------
# Third-party folders
# -----------------------------------------------------
Baileys

grupozap/