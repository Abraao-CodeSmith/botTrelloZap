# ==============================================================================
# CONFIGURAÇÃO DE AMBIENTE - BOT TRELLO-WA
# Renomeie este arquivo para '.env' e insira todas as credenciais aplicáveis.
# ==============================================================================

# Porta do Servidor Web do Bot
PORT=3000
NODE_ENV=development

# --- CONEXÃO COM EVOLUTION API (WHATSAPP) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_evolution_api_key_aqui
EVOLUTION_INSTANCE_NAME=seu_nome_de_instancia_aqui

# --- INTEGRAÇÃO TRELLO ---
TRELLO_KEY=sua_trello_key_aqui
TRELLO_TOKEN=seu_trello_token_aqui
TRELLO_BOARD_ID=id_do_quadro_do_trello_aqui

# IDs de Usuário do Trello adicionados automaticamente por Tag identificada
MEMBER_LASER=id_do_membro_laser_trello
MEMBER_SILK=id_do_membro_silk_trello

# --- CONFIGURAÇÃO DE GRUPOS MONITORADOS (WHATSAPP -> TRELLO) ---
# Formato: JSON em linha única mapeando IDs de grupo do Whatsapp com dados de destino no Trello
# Exemplo abaixo mapeia dois grupos reais diferentes direcionando para listas correspondentes
GROUP_CONFIGS_JSON={"ID_GRUPO_1@g.us":{"nomeIdentificador":"PEDIDOS ANDRESSA","idListaTrello":"ID_LISTA_TRELLO_ANDRESSA","membrosPadrao":["ID_MEMBRO_A","ID_MEMBRO_B"],"idMembroMonitorado":"ID_MEMBRO_A"},"ID_GRUPO_2@g.us":{"nomeIdentificador":"PEDIDOS CANDISSE","idListaTrello":"ID_LISTA_TRELLO_CANDISSE","membrosPadrao":["ID_MEMBRO_C"],"idMembroMonitorado":"ID_MEMBRO_C"}}

# --- MONITORAMENTO DE EMAIL (GMAIL) ---
GMAIL_MONITORED_EMAIL=seu_email_para_monitorar@gmail.com
GMAIL_GROUP_ALERT=id_do_grupo_de_alerta_whatsapp@g.us
GMAIL_CLIENT_ID=seu_google_client_id_oauth.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=seu_google_client_secret_oauth
GMAIL_REFRESH_TOKEN=seu_google_refresh_token_oauth

# --- PERSISTÊNCIA E SESSÕES (SUPABASE DB) ---
SUPABASE_URL=https://seu-id-de-projeto.supabase.co
SUPABASE_KEY=sua_supabase_anon_key_aqui
